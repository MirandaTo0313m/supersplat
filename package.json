{
  "name": "supersplat",
  "version": "1.0.0",
  "description": "3D Gaussian Splat Editor built on PlayCanvas",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "build:prod": "rollup -c --environment NODE_ENV:production",
    "dev": "rollup -c -w",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run build:prod"
  },
  "dependencies": {
    "playcanvas": "^2.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.5",
    "eslint": "^9.0.0",
    "prettier": "^3.2.4",
    "rollup": "^4.9.6",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
